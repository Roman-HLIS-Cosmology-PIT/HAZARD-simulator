Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"GOES", " ", "Proton", " ", "flux", " ", "comparitor"}], "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"dA", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"4088", "*", "4088"}], ")"}], "*", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"10", "*", 
         SuperscriptBox["10", 
          RowBox[{"-", "4"}]]}], ")"}], "2"]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "10", " ", "microns", " ", "by", " ", "10", " ", "microns", " ", "in", 
     " ", 
     SuperscriptBox["cm", "2"], " ", "by", " ", "the", " ", "num", " ", "of", 
     " ", "pix", " ", "squared"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"d\[CapitalOmega]", "=", 
     RowBox[{"2", "*", "Pi"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"2", "pi", " ", "steradians"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"dt", "=", "3.04"}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "exposure", " ", "time", " ", "between", " ", "clock", " ", "reset"}], 
    "*)"}], "\n", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Expected", " ", "rate", " ", "from", " ", "Kruk"}], ",", " ", 
     "Hirata", ",", " ", 
     RowBox[{"et", " ", "al", " ", "2016"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"KHrate", " ", "=", " ", "5.5"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"KHavgFlux", " ", "=", " ", 
     RowBox[{"KHrate", " ", "*", " ", "dA", " ", "*", " ", "dt"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"GOESconverter", "[", "frac_", "]"}], ":=", " ", 
    RowBox[{"frac", "*", "dA", "*", "d\[CapitalOmega]", "*", "dt"}]}], "\n", 
   "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<The expected flux at L2 is \>\"", ",", "KHavgFlux"}], 
    "]"}]}]}]], "Code",
 CellChangeTimes->{{3.9735511786067004`*^9, 3.973551200970233*^9}, {

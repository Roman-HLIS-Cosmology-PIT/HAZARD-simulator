  RowBox[{
   RowBox[{
    RowBox[{
    "url", " ", "=", " ", 
     "\"\<https://services.swpc.noaa.gov/json/goes/primary/integral-protons-\
plot-7-day.json\>\""}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "1.", " ", "Import", " ", "JSON", " ", "as", " ", "a", " ", "list", " ", 
     "of", " ", "Associations"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"data", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"url", ",", " ", "\"\<RawJSON\>\""}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Optional", ":", " ", 
     RowBox[{
     "Inspect", " ", "the", " ", "keys", " ", "available", " ", "in", " ", 
      "one", " ", "record"}]}], " ", "*)"}], "\n", 
   RowBox[{"Keys", "[", 
    RowBox[{"data", "[", 
     RowBox[{"[", "1", "]"}], "]"}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
      "Most", " ", "SWPC", " ", "GOES", " ", "time", " ", "series", " ", 
       "have", " ", "fields", " ", 
       RowBox[{"like", ":", "\n", "   ", "\"\<time_tag\>\""}]}], "  ", "->", 
      " ", 
      RowBox[{
       RowBox[{"ISO", " ", "time", " ", "string", " ", 
        RowBox[{"(", "UTC", ")"}], "\n", "   ", "\"\<flux\>\""}], "      ", "->",
        " ", 
       RowBox[{
        RowBox[{"proton", " ", "flux", " ", 
         RowBox[{"(", 
          RowBox[{"protons", " ", "/", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"cm", "^", "2"}], " ", "s", " ", "sr"}], ")"}]}], ")"}], 
         " ", "for", " ", "a", " ", "given", " ", 
         RowBox[{"channel", " ", ":", 
          RowBox[{
           RowBox[{"contentReference", "[", 
            RowBox[{"oaicite", ":", "0"}], "]"}], 
           RowBox[{"{", 
            RowBox[{"index", "=", "0"}], "}"}], "\n", "   ", 
           "\"\<energy\>\""}]}]}], "    ", "->", " ", 
        RowBox[{"energy", " ", "threshold", " ", "label"}]}]}]}], ",", " ", 
     RowBox[{
      RowBox[{"e", ".", "g", ".", " ", "\\\""}], ">=", 
      RowBox[{"10", " ", "MeV", "\\\""}]}]}], "\n", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "2.", " ", "Convert", " ", "to", " ", "a", " ", "cleaner", " ", 
     "structure", " ", "with", " ", "DateObjects"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"processed", " ", "=", "\n", "  ", 
     RowBox[{"data", " ", "/.", " ", 
      RowBox[{"a_Association", " ", ":>", " ", 
       RowBox[{"<|", "\n", "     ", 
        RowBox[{
         RowBox[{"\"\<time\>\"", "   ", "->", " ", 
          RowBox[{"DateObject", "[", 
           RowBox[{"a", "[", "\"\<time_tag\>\"", "]"}], "]"}]}], ",", "\n", 
         "     ", 
         RowBox[{"\"\<flux\>\"", "   ", "->", " ", 
          RowBox[{"a", "[", "\"\<flux\>\"", "]"}]}], ",", "\n", "     ", 
         RowBox[{"\"\<energy\>\"", " ", "->", " ", 
          RowBox[{"Lookup", "[", 
           RowBox[{
           "a", ",", " ", "\"\<energy\>\"", ",", " ", "\"\<unknown\>\""}], 
           "]"}]}]}], "\n", "   ", "|>"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"3.", " ", "Group", " ", "by", " ", "energy", " ", "channel", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"e", ".", "g", "."}], " ", ">=", 
        RowBox[{"1", " ", "MeV"}]}], ",", " ", 
       RowBox[{">=", 
        RowBox[{"5", " ", "MeV"}]}], ",", " ", 
       RowBox[{">=", 
        RowBox[{"10", " ", "MeV"}]}], ",", " ", 
       RowBox[{"etc", "."}]}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"byEnergy", " ", "=", " ", 
     RowBox[{"GroupBy", "[", 
      RowBox[{"processed", ",", " ", 

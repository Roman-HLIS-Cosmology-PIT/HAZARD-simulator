Cell[TextData[{
 "Casselman vs Chu equation for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "g"], TraditionalForm]],ExpressionUUID->
  "6b016524-cd94-499f-82cd-257f33270d69"],
 " , Chu is the closest to measured values(confirm with Chris who actually \
measured the bandgap)"
}], "Item",

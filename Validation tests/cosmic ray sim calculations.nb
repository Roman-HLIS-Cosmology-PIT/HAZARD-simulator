Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"energyGapCass", "[", 
    RowBox[{"x_", ",", "T_"}], "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"1.92", "*", "x"}], " ", "+", " ", 
    RowBox[{"5.35", "*", 
     RowBox[{"(", 
      SuperscriptBox["10", 
       RowBox[{"-", "4"}]], ")"}], "*", "T", "*", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"2", "*", "x"}]}], ")"}]}], " ", "-", " ", 
    RowBox[{"0.810", "*", 
     SuperscriptBox["x", "2"]}], " ", "+", " ", 
    RowBox[{"0.832", "*", 
     SuperscriptBox["x", "3"]}], " ", "-", " ", "0.302"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"energyGapChu", "[", 
   RowBox[{"x_", ",", "T_"}], "]"}], ":=", " ", 
  RowBox[{
   RowBox[{"1.87", "x"}], " ", "\[Minus]", " ", 
   RowBox[{"0.28", 
    SuperscriptBox["x", "2"]}], "  ", "+", "  ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"6", " ", "\[Minus]", " ", 
      RowBox[{"14", "x"}], " ", "+", " ", 
      RowBox[{"3", 
       SuperscriptBox["x", "2"]}]}], ")"}], "*", 
    RowBox[{"(", 
     SuperscriptBox["10", 
      RowBox[{"-", "4"}]], ")"}], "*", "T"}], " ", "+", " ", 
   RowBox[{"0.35", 
    SuperscriptBox["x", "4"]}], " ", "\[Minus]", " ", "0.295"}]}]}], "Code",
 CellGroupingRules->{"GroupTogetherGrouping", 10000.},

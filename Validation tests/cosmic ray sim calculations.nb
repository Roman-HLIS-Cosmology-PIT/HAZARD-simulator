Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "URL", " ", "of", " ", "the", " ", "GOES", " ", "integral", " ", "proton", 
    " ", "JSON", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "-", "day"}], ",", " ", 

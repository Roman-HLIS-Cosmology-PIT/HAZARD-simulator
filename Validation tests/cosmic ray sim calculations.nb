Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
   "forecastFile", " ", "=", " ", 
    "\"\<C:\\\\Users\\\\Owner\\\\Documents\\\\Hirata \
Group\\\\Code\\\\python\\\\Outputs\\\\ion forecast 2010 to 2030_10 \
instances.h5\>\""}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "List", " ", "the", " ", "elements", " ", "available", " ", "in", " ", 
    "the", " ", "HDF5", " ", "file"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Import", "[", 
    RowBox[{"forecastFile", ",", " ", "\"\<Elements\>\""}], "]"}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Specifically", " ", "list", " ", "datasets"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Import", "[", 
    RowBox[{"forecastFile", ",", " ", "\"\<Datasets\>\""}], "]"}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"allParticles", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"forecastFile", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Datasets\>\"", ",", " ", "\"\<all_particles\>\""}], 
      "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"avgParticles", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"forecastFile", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Datasets\>\"", ",", " ", "\"\<avg_particles\>\""}], 
      "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stdParticles", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"forecastFile", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Datasets\>\"", ",", " ", "\"\<std_particles\>\""}], 
      "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"datesRaw", "    ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"forecastFile", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Datasets\>\"", ",", " ", "\"\<dates\>\""}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"correctedDates", " ", "=", " ", 
    RowBox[{
     RowBox[{"Flatten", "[", "datesRaw", "]"}], "[", 
     RowBox[{"[", 
      RowBox[{";;", " ", ";;", "2"}], "]"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"decimalYearToDate", "[", "dec_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"y", " ", "=", " ", 
        RowBox[{"Floor", "[", "dec", "]"}]}], ",", " ", 
       RowBox[{"f", " ", "=", " ", 
        RowBox[{"FractionalPart", "[", "dec", "]"}]}]}], "}"}], ",", "\n", 
     "  ", 
     RowBox[{"DatePlus", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"y", ",", " ", "1", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"TimeZone", " ", "->", " ", "0"}]}], "]"}], ",", "\n", 
       "    ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"365.25", " ", "f"}], ",", " ", "\"\<Day\>\""}], "}"}]}], 
      "\n", "  ", "]"}]}], "\n", "]"}]}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"comparableDates", " ", "=", " ", 
   RowBox[{"Map", "[", 
    RowBox[{"decimalYearToDate", ",", "correctedDates"}], "]"}]}], 
  ";"}]}], "Code",
 CellChangeTimes->{{3.973552938521255*^9, 3.9735529412064347`*^9}, {

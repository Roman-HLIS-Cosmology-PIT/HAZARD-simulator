    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"4.", " ", "Build", " ", 
     RowBox[{"{", 
      RowBox[{"time", ",", " ", "flux"}], "}"}], " ", "pairs", " ", "for", 
     " ", "each", " ", "energy", " ", "channel"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"series", " ", "=", "\n", "  ", 
     RowBox[{"KeyValueMap", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"energyLabel", ",", " ", "records"}], "}"}], ",", "\n", 
         "      ", 
         RowBox[{"{", "\n", "        ", 
          RowBox[{"energyLabel", ",", "\n", "        ", 
           RowBox[{"records", " ", "/.", " ", 
            RowBox[{"r_Association", " ", ":>", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"r", "[", "\"\<time\>\"", "]"}], ",", " ", 
               RowBox[{"r", "[", "\"\<flux\>\"", "]"}]}], "}"}]}]}]}], "\n", 
          "      ", "}"}]}], "\n", "    ", "]"}], ",", "\n", "    ", 
       "byEnergy"}], "\n", "  ", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "just", " ", "the", " ", "data", " ", "and", " ", 
     "legend", " ", "labels"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"seriesData", "   ", "=", " ", 
     RowBox[{"series", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}], ";"}], " ", "\n", 
   RowBox[{
    RowBox[{"seriesLabels", " ", "=", " ", 
     RowBox[{"series", "[", 
      RowBox[{"[", 
